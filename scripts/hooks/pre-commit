#!/usr/bin/env bash
# Keep the generated artifacts in sync with their sources before every commit:
#   plugin.yml            -> .claude-plugin/plugin.json
#   skills/rules/hooks/*  -> plugin.yml suite.describe
# Install with `just install-hooks`.
#
# A git hook, not a Claude Code hook, on purpose: the no-drift property is a
# property of the commit, so it must hold regardless of editor — a human, a
# rebase, or a scripted/CI bump, none of which fire a Claude Write/Edit hook.
set -euo pipefail

if git diff --cached --name-only | grep -qE '^(plugin\.yml|skills/|rules/|hooks/)'; then
  scripts/shipyard gen-describe
  scripts/shipyard gen-plugin-json
  git add plugin.yml .claude-plugin/plugin.json
fi
