#!/usr/bin/env bash
# Keep plugin.json in sync with plugin.yml. Install with `just install-hooks`.
#
# A git hook, not a Claude Code hook, on purpose: the no-drift property is a
# property of the commit, so it must hold regardless of editor — a human, a
# rebase, or a scripted/CI bump, none of which fire a Claude Write/Edit hook.
set -euo pipefail

if git diff --cached --name-only | grep -qx 'plugin.yml'; then
  python3 scripts/gen-plugin-json.py
  git add .claude-plugin/plugin.json
fi
