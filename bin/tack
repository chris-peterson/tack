#!/usr/bin/env bash
# tack — lazy-build shim. Builds the TS CLI on first run if dist is missing,
# then execs node against it. Used by the Claude plugin install path.
set -e

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DIST="$PLUGIN_ROOT/dist/cli.js"

if [ ! -f "$DIST" ]; then
  if ! command -v npm >/dev/null 2>&1; then
    echo "tack: npm is required to build the CLI on first run" >&2
    exit 1
  fi
  echo "tack: building CLI (one-time)..." >&2
  (cd "$PLUGIN_ROOT" && npm install --silent && npm run build --silent)
fi

exec node "$DIST" "$@"
